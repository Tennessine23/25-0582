<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LEXUS — The Pursuit of Perfection</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --black:    #0a0a0a;
      --charcoal: #1a1a1a;
      --graphite: #2e2e2e;
      --silver:   #8a8a8a;
      --platinum: #c8c8c8;
      --white:    #f5f2ee;
      --gold:     #c9a84c;
      --gold-lt:  #e2c97e;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── NOISE OVERLAY ── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: .5;
    }

    /* ── TYPOGRAPHY ── */
    h1, h2, h3 { font-family: 'Cormorant Garamond', serif; font-weight: 600; letter-spacing: .04em; }
    h1 { font-size: clamp(3rem, 9vw, 8rem); line-height: 1; }
    h2 { font-size: clamp(2rem, 5vw, 3.8rem); }
    h3 { font-size: clamp(1.4rem, 3vw, 2.2rem); }
    h4 { font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); font-weight: 400; }
    p  { color: var(--platinum); font-size: 1.05rem; max-width: 68ch; }
    a  { color: inherit; text-decoration: none; }

    .gold { color: var(--gold); }

    /* ── CONTAINER ── */
    .container { max-width: 1280px; margin: 0 auto; padding: 0 40px; }

    /* ══════════════════════════════════════
       NAVIGATION
    ══════════════════════════════════════ */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 48px;
      background: rgba(10,10,10,.97);
      border-bottom: 1px solid rgba(201,168,76,.15);
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.9rem; font-weight: 700;
      letter-spacing: .25em; color: var(--white);
    }
    .nav-logo span { color: var(--gold); }
    .nav-links { display: flex; list-style: none; gap: 40px; }
    .nav-links li a {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .85rem; letter-spacing: .18em;
      text-transform: uppercase; color: var(--platinum);
      transition: color .25s; padding-bottom: 2px;
      border-bottom: 1px solid transparent;
    }
    .nav-links li a:hover { color: var(--gold); border-bottom-color: var(--gold); }

    /* ══════════════════════════════════════
       PAGE SYSTEM — CSS :target trick
       All pages are stacked; only the
       :target one is visible. Home (#home)
       is shown by default via :not(:target).
    ══════════════════════════════════════ */
    .page {
      display: none;
      min-height: 100vh;
      padding-top: 80px;
    }

    /* Show home by default when no hash is active */
    #home            { display: block; }

    /* When any OTHER page is targeted, hide home */
    body:has(#models:target)  #home,
    body:has(#gallery:target) #home,
    body:has(#about:target)   #home,
    body:has(#contact:target) #home { display: none; }

    /* Show whichever page is targeted */
    #models:target,
    #gallery:target,
    #about:target,
    #contact:target { display: block; }

    /* ── SECTION ── */
    section { padding: 100px 0; }

    .section-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .75rem; letter-spacing: .35em;
      text-transform: uppercase; color: var(--gold);
      display: flex; align-items: center; gap: 14px;
      margin-bottom: 24px;
    }
    .section-label::before { content: ''; width: 32px; height: 1px; background: var(--gold); }

    .divider { width: 64px; height: 1px; background: var(--gold); margin: 32px 0; }
    .divider.center { margin: 32px auto; }

    /* ── LAYOUTS ── */
    .two-col   { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .three-col { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }

    /* ── CARD ── */
    .card {
      background: var(--charcoal);
      border: 1px solid rgba(201,168,76,.12);
      padding: 36px;
      transition: border-color .3s, transform .3s;
    }
    .card:hover { border-color: var(--gold); transform: translateY(-4px); }

    /* ── BUTTON ── */
    .btn {
      display: inline-flex; align-items: center; gap: 12px;
      padding: 16px 40px;
      border: 1px solid var(--gold);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .85rem; letter-spacing: .2em; text-transform: uppercase;
      color: var(--gold); background: transparent;
      transition: all .3s; cursor: pointer;
    }
