<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LEXUS — The Pursuit of Perfection</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --black:    #0a0a0a;
      --charcoal: #1a1a1a;
      --graphite: #2e2e2e;
      --silver:   #8a8a8a;
      --platinum: #c8c8c8;
      --white:    #f5f2ee;
      --cream:    #ede8e0;
      --gold:     #c9a84c;
      --gold-lt:  #e2c97e;
      --red:      #b22222;
      --shadow:   rgba(0,0,0,0.45);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      line-height: 1.7;
      overflow-x: hidden;
    }
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: .5;
    }

    h1, h2, h3 { font-family: 'Cormorant Garamond', serif; font-weight: 600; letter-spacing: .04em; }
    h1 { font-size: clamp(3rem, 9vw, 8rem); line-height: 1; }
    h2 { font-size: clamp(2rem, 5vw, 3.8rem); }
    h3 { font-size: clamp(1.4rem, 3vw, 2.2rem); }
    h4 { font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); font-weight: 400; }
    p { color: var(--platinum); font-size: 1.05rem; max-width: 68ch; }
    a { color: inherit; text-decoration: none; }

    .gold  { color: var(--gold); }
    .upper { text-transform: uppercase; letter-spacing: .2em; font-size: .8rem; }
    .center { text-align: center; }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 40px;
    }

    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 48px;
      background: linear-gradient(to bottom, rgba(10,10,10,.98), rgba(10,10,10,0));
      transition: background .4s;
    }
    nav.scrolled { background: rgba(10,10,10,.97); border-bottom: 1px solid rgba(201,168,76,.15); }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.9rem;
      font-weight: 700;
      letter-spacing: .25em;
      color: var(--white);
    }
    .nav-logo span { color: var(--gold); }
    .nav-links { display: flex; list-style: none; gap: 40px; }
    .nav-links li a {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .85rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--platinum);
      transition: color .25s;
      padding-bottom: 2px;
      border-bottom: 1px solid transparent;
    }
    .nav-links li a:hover,
    .nav-links li a.active { color: var(--gold); border-bottom-color: var(--gold); }

    .page { display: none; min-height: 100vh; }
    .page.active { display: block; }

    .hero {
      position: relative;
      height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background:
        linear-gradient(135deg, rgba(10,10,10,.85) 40%, rgba(10,10,10,.3)),
        url('https://images.unsplash.com/photo-1550355291-bbee04a92027?w=1600&q=80') center/cover no-repeat;
    }
    .hero-content { position: relative; z-index: 2; padding-left: 80px; }
    .hero-eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .75rem;
      letter-spacing: .35em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .hero-eyebrow::before { content: ''; width: 48px; height: 1px; background: var(--gold); }
    .hero h1 { color: var(--white); margin-bottom: 20px; }
    .hero-sub { font-size: 1.25rem; color: var(--platinum); margin-bottom: 48px; font-weight: 300; }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 16px 40px;
      border: 1px solid var(--gold);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .85rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--gold);
      background: transparent;
      cursor: pointer;
      transition: all .3s;
    }
    .btn:hover { background: var(--gold); color: var(--black); }
    .btn-solid { background: var(--gold); color: var(--black); }
    .btn-solid:hover { background: var(--gold-lt); }

    section { padding: 100px 0; }

    .section-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: .75rem;
      letter-spacing: .35em;
      text-transform: uppercase;
      color: var(--gold);
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 24px;
    }
    .section-label::before { content: ''; width: 32px; height: 1px; background: var(--gold); }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .two-col.reverse { direction: rtl; }
    .two-col.reverse > * { direction: ltr; }
    .three-col { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }

    .divider { width: 64px; height: 1px; background: var(--gold); margin: 32px 0; }
    .divider.center { margin: 32px auto; }

    .card {
      background: var(--charcoal);
      border: 1px solid rgba(201,168,76,.12);
      padding: 36px;
      transition: border-color .3s, transform .3s;
    }
    .card:hover { border-color: var(--gold); transform: translateY(-4px); }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto auto;
      gap: 12px;
    }
    .gallery-grid .featured { grid-column: span 2; grid-row: span 2; }
    .gallery-img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .5s, filter .5s;
      filter: brightness(.9) saturate(.8);
      min-height: 240px;
    }
    .gallery-item { overflow: hidden; position: relative; }
    .gallery-item::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,.5), transparent 50%);
      pointer-events: none;
    }
    .gallery-item:hover .gallery-img { transform: scale(1.06); filter: brightness(1) saturate(1); }

    .video-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .video-grid .full-width { grid-column: span 2; }
    .video-wrapper {
      position: relative;
      background: var(--charcoal);
      border: 1px solid rgba(201,168,76,.1);
      overflow: hidden;
    }
    .video-wrapper iframe { width: 100%; display: block; }

    .table-wrap { overflow-x: auto; margin: 40px 0; border: 1px solid rgba(201,168,76,.15); }
    table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    thead tr { background: linear-gradient(90deg, var(--charcoal), var(--graphite)); }
    thead th {
      padding: 16px 20px;
      text-align: left;
      font-family: 'Barlow Condensed', sans-serif;
      letter-spacing: .15em;
      text-transform: uppercase;
      font-size: .78rem;
      color: var(--gold);
      border-bottom: 2px solid var(--gold);
      font-weight: 400;
    }
    tbody tr { border-bottom: 1px solid rgba(255,255,255,.05); transition: background .2s; }
    tbody tr:hover { background: rgba(201,168,76,.05); }
    tbody td { padding: 14px 20px; color: var(--platinum); }
    tbody td:first-child { color: var(--white); font-weight: 500; }
    tfoot tr { background: var(--graphite); }
    tfoot td { padding: 14px 20px; color: var(--gold); font-family: 'Barlow Condensed', sans-serif; letter-spacing: .1em; }

    .luxury-list { list-style: none; padding: 0; }
    .luxury-list > li {
      border-left: 2px solid var(--gold);
      padding: 20px 28px;
      margin-bottom: 4px;
      background: rgba(201,168,76,.04);
      transition: background .3s;
    }
    .luxury-list > li:hover { background: rgba(201,168,76,.08); }
    .luxury-list > li > .list-title { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; color: var(--white); margin-bottom: 8px; }
    .luxury-list ul { list-style: none; padding-left: 20px; margin-top: 10px; }
    .luxury-list ul li { color: var(--silver); font-size: .9rem; padding: 4px 0; padding-left: 16px; position: relative; }
    .luxury-list ul li::before { content: '—'; position: absolute; left: 0; color: var(--gold); }

    .lead-para { font-size: 1.2rem; color: var(--platinum); line-height: 1.9; border-left: 3px solid var(--gold); padding-left: 28px; }
    .body-para { font-size: 1rem; color: var(--silver); line-height: 1.85; }
    .highlight-para {
      background: rgba(201,168,76,.07);
      border: 1px solid rgba(201,168,76,.2);
      padding: 28px 36px;
      font-style: italic;
      color: var(--platinum);
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      line-height: 1.8;
    }

    .spec-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: rgba(201,168,76,.1);
      border: 1px solid rgba(201,168,76,.1);
      margin: 40px 0;
    }
    .spec-item { background: var(--charcoal); padding: 32px 24px; text-align: center; }
    .spec-number { font-family: 'Cormorant Garamond', serif; font-size: 3rem; color: var(--gold); line-height: 1; margin-bottom: 8px; }
    .spec-label { font-family: 'Barlow Condensed', sans-serif; font-size: .7rem; letter-spacing: .2em; text-transform: uppercase; color: var(--silver); }

    .model-card { position: relative; overflow: hidden; border: 1px solid rgba(201,168,76,.1); aspect-ratio: 4/3; }
    .model-card img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .6s; filter: brightness(.7); }
    .model-card:hover img { transform: scale(1.08); filter: brightness(.5); }
    .model-card-overlay {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 32px;
      background: linear-gradient(to top, rgba(0,0,0,.85) 30%, transparent);
    }
    .model-price { font-family: 'Barlow Condensed', sans-serif; font-size: .75rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; }
    .model-name { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; color: var(--white); }

    .testimonial { background: var(--charcoal); border: 1px solid rgba(201,168,76,.12); padding: 48px; position: relative; }
    .testimonial::before {
      content: '"'; position: absolute; top: -20px; left: 40px;
      font-family: 'Cormorant Garamond', serif; font-size: 10rem; color: var(--gold); opacity: .15; line-height: 1;
    }
    .testimonial-text { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: var(--white); line-height: 1.7; margin-bottom: 24px; }
    .testimonial-author { font-family: 'Barlow Condensed', sans-serif; font-size: .8rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); }

    .form-group { margin-bottom: 24px; }
    label { display: block; font-family: 'Barlow Condensed', sans-serif; font-size: .75rem; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
    input, select, textarea { width: 100%; padding: 14px 18px; background: var(--charcoal); border: 1px solid rgba(201,168,76,.2); color: var(--white); font-family: 'Barlow', sans-serif; font-size: .95rem; outline: none; transition: border-color .3s; }
    input:focus, select:focus, textarea:focus { border-color: var(--gold); }
    textarea { resize: vertical; min-height: 140px; }
    select option { background: var(--charcoal); }

    footer { background: var(--charcoal); border-top: 1px solid rgba(201,168,76,.15); padding: 64px 0 32px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; margin-bottom: 60px; }
    .footer-brand p { color: var(--silver); font-size: .9rem; margin-top: 16px; }
    .footer-col h5 { font-family: 'Barlow Condensed', sans-serif; font-size: .75rem; letter-spacing: .25em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; font-weight: 400; }
    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: 10px; }
    .footer-col ul li a { color: var(--silver); font-size: .9rem; transition: color .25s; }
    .footer-col ul li a:hover { color: var(--gold); }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,.06); padding-top: 28px; display: flex; justify-content: space-between; align-items: center; }
    .footer-bottom p { font-size: .8rem; color: var(--silver); max-width: none; }

    .page-banner {
      height: 40vh; min-height: 320px;
      display: flex; align-items: flex-end; padding-bottom: 60px;
      position: relative; overflow: hidden; margin-top: 80px;
    }
    .page-banner .bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(.4) saturate(.6); }
    .page-banner .overlay { position: absolute; inset: 0; background: linear-gradient(to top, var(--black) 0%, transparent 60%); }
    .page-banner .content { position: relative; z-index: 2; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { animation: fadeUp .7s ease forwards; }
    .fade-up.d1 { animation-delay: .1s; opacity: 0; }
    .fade-up.d2 { animation-delay: .25s; opacity: 0; }
    .fade-up.d3 { animation-delay: .4s; opacity: 0; }
    .fade-up.d4 { animation-delay: .55s; opacity: 0; }

    .timeline { position: relative; padding-left: 40px; }
    .timeline::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 1px; background: rgba(201,168,76,.25); }
    .timeline-item { position: relative; margin-bottom: 48px; }
    .timeline-item::before { content: ''; position: absolute; left: -44px; top: 6px; width: 8px; height: 8px; border: 1px solid var(--gold); background: var(--black); transform: rotate(45deg); }
    .timeline-year { font-family: 'Barlow Condensed', sans-serif; font-size: .75rem; letter-spacing: .25em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--black); }
    ::-webkit-scrollbar-thumb { background: var(--graphite); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--gold); }

    @media (max-width: 900px) {
      .two-col { grid-template-columns: 1fr; gap: 40px; }
      .three-col { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .spec-grid { grid-template-columns: 1fr 1fr; }
      .nav-links { gap: 20px; }
      .hero-content { padding-left: 24px; }
      .gallery-grid { grid-template-columns: 1fr 1fr; }
      .gallery-grid .featured { grid-column: span 2; grid-row: span 1; }
    }
  </style>
</head>
<body>

<nav id="navbar">
  <div class="nav-logo">LEX<span>U</span>S</div>
  <ul class="nav-links">
    <li><a href="#" onclick="showPage('home')" class="active" data-page="home">Home</a></li>
    <li><a href="#" onclick="showPage('models')" data-page="models">Models</a></li>
    <li><a href="#" onclick="showPage('gallery')" data-page="gallery">Gallery</a></li>
